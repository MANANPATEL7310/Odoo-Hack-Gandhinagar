{
  "name": "@template/workspace",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @template/web dev",
    "dev:api": "pnpm --filter @template/api dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "clean": "turbo clean",
    "prepare": "husky",
    "gen:module": "bash scripts/gen-module.sh",
    "gen:feature": "bash scripts/gen-feature.sh",
    "db:push": "pnpm --filter @template/api exec prisma db push",
    "db:seed": "pnpm --filter @template/api exec prisma db seed",
    "db:studio": "pnpm --filter @template/api exec prisma studio",
    "db:migrate": "pnpm --filter @template/api exec prisma migrate dev",
    "db:generate": "pnpm --filter @template/api exec prisma generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@template/eslint-config": "workspace:*",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "prisma": "^5.22.0"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md,css,mjs,yml,yaml}": "prettier --write"
  }
}
